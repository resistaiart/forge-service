# ================================
# Forge API .env Configuration
# ================================

# General
ENV=production
DEBUG=false
PORT=8000

# CORS - supports JSON array or comma-separated list
# Example JSON: ["*"]
# Example CSV: http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=["*"]

# Feature Toggles
FORGE_ENABLE_LEGACY=true

# ================================
# Chroma DB Configuration
# ================================

# Server Configuration
CHROMA_SERVER_HOST=0.0.0.0
CHROMA_SERVER_HTTP_PORT=8000
CHROMA_SERVER_GRPC_PORT=50051

# CORS Settings - JSON array or comma-separated list
# Example JSON:
# CHROMA_SERVER_CORS_ALLOW_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
# Example CSV:
# CHROMA_SERVER_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CHROMA_SERVER_CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Persistence
CHROMA_PERSIST_DIRECTORY=./chroma_db
